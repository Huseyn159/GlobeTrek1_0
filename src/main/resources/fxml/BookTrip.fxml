<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="20.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.BookTripController">
    <padding>
        <Insets top="30" bottom="30" left="20" right="20"/>
    </padding>

    <Label styleClass="header-label" text="Book a New Trip" />

    <VBox alignment="CENTER" spacing="15.0" styleClass="card">
        <VBox alignment="CENTER_LEFT" spacing="5.0">
            <Label text="From Country:" />
            <ComboBox fx:id="fromCountryComboBox" prefWidth="250.0" promptText="Select origin country" styleClass="combo-box"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5.0">
            <Label text="To Country:" />
            <ComboBox fx:id="toCountryComboBox" prefWidth="250.0" promptText="Select destination country" styleClass="combo-box"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5.0">
            <Label text="Flight Type:" />
            <ComboBox fx:id="flightTypeComboBox" prefWidth="250.0" promptText="Select flight type" styleClass="combo-box"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5.0">
            <Label text="Travel Date:" />
            <DatePicker fx:id="travelDatePicker" prefWidth="250.0" promptText="Select travel date" styleClass="date-picker"/>
        </VBox>

        <Label fx:id="costLabel" styleClass="sub-header-label" text="Estimated Cost: $0.00"/>
        <Label fx:id="errorLabel" styleClass="error-label" text=""/>
        <Button onAction="#handleBookTrip" styleClass="button" text="Book Trip"/>
    </VBox>
</VBox>
