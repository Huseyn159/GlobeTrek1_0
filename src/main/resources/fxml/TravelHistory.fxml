<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="20.0" styleClass="root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.TravelHistoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label styleClass="header-label" text="Travel History" />

    <TableView fx:id="travelHistoryTable" prefHeight="400.0" prefWidth="600.0" styleClass="table-view">
        <columns>
            <TableColumn fx:id="fromColumn" prefWidth="100.0" text="From" />
            <TableColumn fx:id="toColumn" prefWidth="100.0" text="To" />
            <TableColumn fx:id="flightTypeColumn" prefWidth="100.0" text="Flight Type" />
            <TableColumn fx:id="visaRequiredColumn" prefWidth="100.0" text="Visa Required" />
            <TableColumn fx:id="costColumn" prefWidth="100.0" text="Cost" />
            <TableColumn fx:id="dateColumn" prefWidth="100.0" text="Date" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <Label fx:id="noTripsLabel" styleClass="label" text="You have no trips yet." visible="false" />
</VBox>