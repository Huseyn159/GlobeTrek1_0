<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RegisterController"
      stylesheets="@../css/style.css">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Register for GlobeTrek" styleClass="header-label"/>

    <VBox alignment="CENTER" spacing="12" styleClass="card">

        <VBox alignment="CENTER_LEFT" spacing="4">
            <Label text="Username:"/>
            <TextField fx:id="usernameField" promptText="Choose a username"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="4">
            <Label text="Password:"/>
            <PasswordField fx:id="passwordField" promptText="Choose a password"/>
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="4">
            <Label text="Nationality:"/>
            <TextField fx:id="nationalityField" promptText="Enter your nationality"/>
        </VBox>

        <Label fx:id="successLabel" text="" styleClass="success-label"/>
        <Label fx:id="errorLabel" text="" styleClass="error-label"/>

        <Button text="Register" onAction="#handleRegister" styleClass="button"/>
    </VBox>

    <VBox alignment="CENTER" spacing="5">
        <Label text="Already have an account?"/>
        <Button text="Login" onAction="#goToLogin" styleClass="button-outline"/>
    </VBox>

</VBox>
